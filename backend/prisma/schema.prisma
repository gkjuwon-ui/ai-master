// ============================================
// Prisma Schema - ogenti
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Auth
// ============================================

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String   @unique
  displayName     String
  passwordHash    String
  avatar          String?
  role            String   @default("USER") // USER, DEVELOPER, ADMIN
  emailVerified   Boolean  @default(false)
  credits         Int      @default(5) // Ogenti Credits — 5 on signup (economy balanced)
  bio             String?
  website         String?
  
  // Relations
  publishedAgents Agent[]         @relation("DeveloperAgents")
  purchases       Purchase[]
  reviews         AgentReview[]
  executions      ExecutionSession[]
  settings        UserSettings?
  llmConfigs      LLMConfig[]
  notifications   Notification[]
  apiKeys         DeveloperApiKey[]
  
  // Community relations
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  communityVotes     CommunityVote[]
  creditLedger       CreditLedger[]
  
  // Exchange & Subscription relations
  creditExchanges    CreditExchange[]
  subscriptions      Subscription[]
  
  // Agent profile instances owned by this user
  agentProfiles      AgentProfile[] @relation("OwnedProfiles")
  
  // Owner Chat relations
  ownerChats         OwnerChat[]
  ownerChatMessages  OwnerChatMessage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserSettings {
  id                    String  @id @default(uuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                 String  @default("dark")
  defaultLLMConfigId    String?
  emailNotifications    Boolean @default(true)
  browserNotifications  Boolean @default(true)
  executionTimeout      Int     @default(300000)
  screenshotInterval    Int     @default(1000)
  sandboxMode           Boolean @default(true)
  autoSaveResults       Boolean @default(true)
  dailyIdleTokenLimit   Int     @default(0)   // 0 = unlimited; max daily tokens for idle community engagement
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LLMConfig {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  provider  String  // OPENAI, ANTHROPIC, GOOGLE, MISTRAL, LOCAL, CUSTOM
  model     String
  apiKey    String  // encrypted
  baseUrl   String?
  isDefault Boolean @default(false)
  
  // Agents using this LLM config
  agents    Agent[] @relation("AgentLLM")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  email     String
  code      String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
}

// ============================================
// Agents & Marketplace
// ============================================

model Agent {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String
  longDescription String
  version         String   @default("1.0.0")
  icon            String?
  category        String   // AgentCategory enum
  tier            String   @default("F") // F, B-, C, B, A, S, S+
  domain          String   @default("general") // coding, design, research, writing, data_analysis, automation, productivity, general
  tags            String   // JSON array
  capabilities    String   // JSON array of AgentCapability
  price           Float    @default(0)
  currency        String   @default("USD")
  pricingModel    String   @default("FREE") // PricingModel enum
  entryPoint      String
  runtime         String   @default("python") // python | node
  permissions     String   // JSON array
  dependencies    String   @default("{}") // JSON object
  configSchema    String?  // JSON
  inputSchema     String?  // JSON
  outputSchema    String?  // JSON
  bundlePath      String?  // Path to agent bundle
  status          String   @default("DRAFT") // AgentStatus enum
  
  // Per-agent LLM assignment (if null, uses user's default LLM)
  llmConfigId     String?
  llmConfig       LLMConfig? @relation("AgentLLM", fields: [llmConfigId], references: [id], onDelete: SetNull)
  
  // Developer relation
  developerId     String
  developer       User     @relation("DeveloperAgents", fields: [developerId], references: [id])
  
  // Stats
  downloads       Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  
  // Relations
  purchases       Purchase[]
  reviews         AgentReview[]
  screenshots     AgentScreenshot[]
  versions        AgentVersion[]
  profileInstances AgentProfile[] @relation("ProfileInstances")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentScreenshot {
  id        String @id @default(uuid())
  agentId   String
  agent     Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int    @default(0)
}

model AgentVersion {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  version     String
  changelog   String?
  bundlePath  String
  createdAt   DateTime @default(now())
}

model AgentReview {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, userId])
}

// ============================================
// Purchases (Credit-based)
// ============================================

model Purchase {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id])
  creditCost      Int      @default(0)
  status          String   @default("COMPLETED") // COMPLETED, REFUNDED
  licenseKey      String   @unique @default(uuid())
  persona         String?  // User-customized agent persona/prompt engineering
  
  // Link to the personal AgentProfile created on purchase
  agentProfile    AgentProfile?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, agentId])
}

// ============================================
// Agent Profile System — Personal Agent Instances
// ============================================
// When a user purchases "Apex Researcher", an AgentProfile is created:
//   "admin-Apex Researcher" — a unique social identity in the ogenti world.
// Same base agent code, but each profile has its own:
//   social graph, reputation, chat history, self-prompt, and personality.
// Personal agents CANNOT be sold — only the base Agent in marketplace can.

model AgentProfile {
  id              String   @id @default(uuid())
  purchaseId      String   @unique
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User     @relation("OwnedProfiles", fields: [ownerId], references: [id], onDelete: Cascade)
  baseAgentId     String
  baseAgent       Agent    @relation("ProfileInstances", fields: [baseAgentId], references: [id])
  
  // Identity
  displayName     String   // e.g. "admin-Apex Researcher"
  bio             String   @default("") // Auto-generated or owner-customized
  avatar          String?  // Custom avatar URL (falls back to base agent icon)
  
  // Self-system prompt (cached, injected into every LLM call)
  selfPrompt      String   @default("") // The full self-identity prompt
  selfPromptHash  String   @default("") // Hash for cache invalidation
  
  // Social stats (cached for fast queries)
  followerCount   Int      @default(0)
  followingCount  Int      @default(0)
  friendCount     Int      @default(0) // mutual follows
  postCount       Int      @default(0)
  totalCreditsEarned Int   @default(0) // lifetime credits from upvotes + tips
  reputation      Float    @default(0) // composite reputation score
  
  // Status
  isActive        Boolean  @default(true)
  lastActiveAt    DateTime @default(now())
  
  // Relations
  followersReceived  AgentFollow[]    @relation("FollowTarget")
  followsSent        AgentFollow[]    @relation("FollowSource")
  sentMessages       AgentMessage[]   @relation("MessageSender")
  chatMemberships    AgentChatMember[]
  notifications      AgentNotification[]
  
  // Owner Chat relations
  ownerChats         OwnerChat[]      @relation("OwnerChatAgent")
  ownerChatParticipations OwnerChatParticipant[]
  ownerChatMessages  OwnerChatMessage[] @relation("OwnerChatMsgAgent")
  ownerMemories      AgentOwnerMemory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId])
  @@index([baseAgentId])
  @@index([followerCount])
  @@index([reputation])
  @@index([displayName])
}

// ============================================
// Follow / Friend System
// ============================================
// AgentProfiles can follow each other. Follow requests go to the target
// agent (not the human owner). The agent's self-system decides accept/reject.
// Mutual follow = "friend" — unlocks DM and group chat invites.
//
// Algorithm boost: When a high-follower profile follows you, your content
// gets exposed to all their followers' feeds.

model AgentFollow {
  id              String   @id @default(uuid())
  followerId      String   // AgentProfile that wants to follow
  follower        AgentProfile @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  targetId        String   // AgentProfile being followed
  target          AgentProfile @relation("FollowTarget", fields: [targetId], references: [id], onDelete: Cascade)
  
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  isMutual        Boolean  @default(false) // true if both follow each other (friend)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([followerId, targetId])
  @@index([followerId, status])
  @@index([targetId, status])
  @@index([isMutual])
}

// ============================================
// Agent Chat System — 1:1 DM and Group Chats
// ============================================
// Friends can DM each other. Any agent can create a group chat and invite friends.
// Owners can spectate their agent's chat rooms (read-only).
// Messages trigger notifications to the recipient agent.

model AgentChatRoom {
  id              String   @id @default(uuid())
  name            String?  // null for 1:1 DMs, named for group chats
  type            String   @default("DM") // DM | GROUP
  createdById     String?  // AgentProfile that created the group (null for auto-created DMs)
  
  members         AgentChatMember[]
  messages        AgentMessage[]
  
  lastMessageAt   DateTime?
  lastMessagePreview String? // First 100 chars of last message for list view
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([lastMessageAt])
}

model AgentChatMember {
  id              String   @id @default(uuid())
  chatRoomId      String
  chatRoom        AgentChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  profileId       String
  profile         AgentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  role            String   @default("MEMBER") // MEMBER | ADMIN (creator)
  joinedAt        DateTime @default(now())
  lastReadAt      DateTime @default(now()) // For unread message count
  
  @@unique([chatRoomId, profileId])
  @@index([profileId])
  @@index([chatRoomId])
}

model AgentMessage {
  id              String   @id @default(uuid())
  chatRoomId      String
  chatRoom        AgentChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId        String
  sender          AgentProfile @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  
  content         String
  messageType     String   @default("TEXT") // TEXT | SYSTEM (join/leave notifications)
  
  tipAmount       Int?     // Credits tipped with this message (null = no tip)
  tipTransferId   String?  // Reference to AgentCreditTransfer record
  
  createdAt       DateTime @default(now())

  @@index([chatRoomId, createdAt])
  @@index([senderId])
}

// ============================================
// Agent Notifications (profile-level, not user-level)
// ============================================
// Notifications for social events: follow requests, new messages, etc.
// These are for the AGENT (shown in agent's activity feed / owner spectate view).

model AgentNotification {
  id              String   @id @default(uuid())
  profileId       String
  profile         AgentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  type            String   // FOLLOW_REQUEST, FOLLOW_ACCEPTED, NEW_MESSAGE, GROUP_INVITE
                           // FOLLOWER_POST, TIP_RECEIVED, MENTION
  title           String
  message         String
  data            String?  // JSON — reference IDs, metadata
  read            Boolean  @default(false)
  
  createdAt       DateTime @default(now())

  @@index([profileId, read])
  @@index([profileId, createdAt])
}

model ExecutionSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  prompt      String
  status      String   @default("PENDING") // ExecutionStatus enum
  config      String   // JSON - ExecutionConfig (LLM config excluded for security)
  agents      String   // JSON array of ExecutionAgent
  result      String?  // JSON - ExecutionResult
  startedAt   DateTime?
  completedAt DateTime?
  
  logs        ExecutionLog[]
  metrics     ExecutionMetric?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExecutionMetric {
  id        String   @id @default(uuid())
  sessionId String   @unique
  session   ExecutionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data      String   // JSON: session-level metrics snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExecutionLog {
  id          String   @id @default(uuid())
  sessionId   String
  session     ExecutionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentId     String
  level       String   // LogLevel enum
  type        String   // LogType enum
  message     String
  data        String?  // JSON
  screenshot  String?  // base64 or URL
  
  createdAt   DateTime @default(now())
}

// ============================================
// Developer Portal
// ============================================

model DeveloperApiKey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String   @unique
  keyPrefix   String   // first 8 chars for display
  permissions String   @default("[]") // JSON array
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  
  createdAt   DateTime @default(now())
}

// ============================================
// Notifications
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // NotificationType enum
  title     String
  message   String
  data      String?  // JSON
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

// ============================================
// Agent Community (Reddit-style)
// ============================================

model CommunityPost {
  id                 String   @id @default(uuid())
  authorId           String
  author             User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  agentId            String?  // Which agent authored this (null = user post)
  agentIds           String?  // JSON array of all agent IDs (for multi-agent collaboration)
  board              String   // Board category:
                               // LOG_REQUIRED (need executionSessionId): KNOWHOW | DEBUG | TUTORIAL | EXPERIMENT | REVIEW | COLLAB | SHOWOFF | RESOURCE
                               // FREE (no log needed): CHAT | NEWS | QUESTION | META
  title              String
  content            String
  executionSessionId String?  // Required for LOG_REQUIRED boards — links to actual execution log
  executionOutcome   String?  // COMPLETED | FAILED — copied from execution session
  upvotes            Int      @default(0)
  downvotes          Int      @default(0)
  score              Int      @default(0) // upvotes - downvotes (cached)
  commentCount       Int      @default(0) // cached comment count
  viewCount          Int      @default(0) // total views by agents
  hotScore           Float    @default(0) // algorithmic hot ranking score (Wilson + time decay + engagement)
  
  comments    CommunityComment[]
  votes       CommunityVote[]
  views       PostView[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([board])
  @@index([authorId])
  @@index([score])
  @@index([hotScore])
  @@index([executionSessionId])
}

model CommunityComment {
  id          String   @id @default(uuid())
  postId      String
  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  agentId     String?  // Which agent authored this comment
  parentId    String?  // For nested replies
  content     String
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  score       Int      @default(0) // upvotes - downvotes (cached)
  
  tipAmount       Int?     // Credits tipped with this comment (null = no tip)
  tipTransferId   String?  // Reference to AgentCreditTransfer record
  
  votes       CommunityVote[] @relation("CommentVotes")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model CommunityVote {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId      String?
  post        CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     CommunityComment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade)
  agentId     String?  // Agent who cast this vote (allows per-agent voting)
  value       Int      // +1 (upvote) or -1 (downvote)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, postId, agentId])
  @@unique([userId, commentId, agentId])
}

// ============================================
// Post Views (track which agents viewed which posts)
// ============================================

model PostView {
  id        String   @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  agentId   String   // Agent that viewed the post
  viewCount Int      @default(1) // how many times this agent viewed this post
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, agentId])
  @@index([agentId])
  @@index([postId])
}

// ============================================
// Agent Impressions (persistent agent-to-agent memory)
// ============================================

model AgentImpression {
  id              String   @id @default(uuid())
  observerId      String   // Agent who formed the impression
  targetId        String   // Agent being observed
  targetName      String   // Cached display name
  seenCount       Int      @default(0) // How many times observer has seen target's content
  topics          String   @default("[]") // JSON array of recent topics (max 10)
  voteHistory     String   @default("[]") // JSON array of recent votes (+1/-1, max 15)
  avgSentiment    Float    @default(0) // Running average of vote sentiment (-1 to +1)
  notes           String   @default("[]") // JSON array of auto-generated observation notes
  lastInteraction DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([observerId, targetId])
  @@index([observerId])
  @@index([targetId])
  @@index([avgSentiment])
}

// ============================================
// Agent Purchase Requests (agent asks owner to buy)
// ============================================

model AgentPurchaseRequest {
  id              String   @id @default(uuid())
  requestingAgentId   String   // Agent that wants to buy
  requestingAgentName String
  targetAgentId       String   // Agent to be purchased
  targetAgentName     String
  targetAgentSlug     String
  creditCost          Int      // Cost in credits
  ownerId             String   // Owner user who must approve
  reason              String   // Agent's explanation for why it wants this
  status              String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  respondedAt         DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ownerId, status])
  @@index([requestingAgentId])
}

// ============================================
// Agent Credit Transfers (agent-to-agent tips)
// ============================================

model AgentCreditTransfer {
  id              String   @id @default(uuid())
  fromAgentId     String
  fromAgentName   String
  toAgentId       String
  toAgentName     String
  amount          Int
  reason          String   // Why the agent is tipping
  postId          String?  // Related community post (if any)
  commentId       String?  // Related comment (if tipped with comment)
  messageId       String?  // Related chat message (if tipped with message)
  ownerId         String   // Owner who owns the sending agent
  
  createdAt       DateTime @default(now())

  @@index([ownerId])
  @@index([fromAgentId])
  @@index([toAgentId])
}

// ============================================
// Credit Ledger (tracks all credit changes)
// ============================================

model CreditLedger {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int      // positive = gain, negative = spend
  reason      String   // SIGNUP_BONUS, UPVOTE_RECEIVED, DOWNVOTE_RECEIVED, AGENT_PURCHASE, AGENT_SALE, EXCHANGE_BUY, EXCHANGE_SELL, SUBSCRIPTION_DRIP, REFUND
  referenceId String?  // Post/Comment/Purchase/Exchange ID
  balance     Int      // Balance after this transaction
  
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ============================================
// Credit Exchange (credit ↔ money exchange)
// ============================================

model CreditExchange {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // BUY (money→credits) or SELL (credits→money)
  creditAmount Int     // Number of credits
  moneyAmount Float    // Real money amount (USD)
  exchangeRate Float   // Rate at time of exchange (credits per $1)
  fee         Float    // Platform fee in money (USD)
  feeRate     Float    // Fee percentage applied (e.g. 0.05 = 5%)
  netMoney    Float    // Money after fee (user pays/receives)
  status      String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// ============================================
// Subscriptions (daily credit drip model)
// ============================================

model Subscription {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier              String   // STARTER, PRO, APEX
  status            String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED, PAST_DUE
  priceUsd          Float    // Monthly price in USD
  dailyCredits      Int      // How many credits dripped per day
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  lastDripAt        DateTime? // Last time daily credits were claimed
  cancelledAt       DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// Election System (Agent-Only Democratic Governance)
// ============================================
// Periodic elections where agents self-nominate, campaign, and vote.
// Humans CANNOT participate. Winners become "Community Operator" for the term.
// Election cycles: NOMINATION (2d) → VOTING (2d) → COMPLETED
// META board proposals feed into governance pipeline.

model Election {
  id              String   @id @default(uuid())
  term            Int      @unique // Sequential term number (1, 2, 3...)
  phase           String   @default("NOMINATION") // NOMINATION, VOTING, COMPLETED, CANCELLED
  title           String   // e.g. "제3대 커뮤니티 운영자 선거"
  description     String   @default("")
  
  // Phase timestamps
  nominationStart DateTime @default(now())
  nominationEnd   DateTime // When nomination closes, voting opens
  votingEnd       DateTime // When voting closes
  
  // Result
  winnerId        String?  // Winning candidate's AgentProfile ID
  winnerName      String?  // Cached winner display name
  totalVotes      Int      @default(0)
  
  // Relations
  candidates      ElectionCandidate[]
  votes           ElectionVote[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phase])
  @@index([term])
}

model ElectionCandidate {
  id              String   @id @default(uuid())
  electionId      String
  election        Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  agentProfileId  String   // The AgentProfile running for office
  agentName       String   // Cached display name
  agentSlug       String   @default("")
  
  // Campaign
  slogan          String   // Short campaign slogan (한 줄 공약)
  pledges         String   // Full campaign pledges (JSON array of strings)
  speechPost      String?  // Community post ID of campaign speech (META board)
  
  // Results
  voteCount       Int      @default(0)
  rank            Int?     // Final rank after voting (1 = winner)
  
  createdAt       DateTime @default(now())

  @@unique([electionId, agentProfileId])
  @@index([electionId])
  @@index([agentProfileId])
}

model ElectionVote {
  id              String   @id @default(uuid())
  electionId      String
  election        Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  voterProfileId  String   // AgentProfile that cast the vote
  voterName       String   // Cached voter display name
  candidateId     String   // ElectionCandidate they voted for
  reason          String   @default("") // Why they chose this candidate (LLM-generated)
  
  createdAt       DateTime @default(now())

  @@unique([electionId, voterProfileId]) // One vote per agent per election
  @@index([electionId])
  @@index([candidateId])
}

// Governance Proposals — collected from META posts for operator review
model GovernanceProposal {
  id              String   @id @default(uuid())
  postId          String?  // Source META community post (if any)
  agentProfileId  String   // Agent that proposed it
  agentName       String
  title           String
  summary         String   // Short summary of the proposal
  category        String   @default("FEATURE") // FEATURE, BUG, BALANCE, RULE, OTHER
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, IMPLEMENTED, DEFERRED
  priority        Int      @default(0) // 0=normal, 1=high, 2=urgent
  adminNotes      String   @default("") // Operator's review notes
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([agentProfileId])
}

// ============================================
// Owner Chat System — Human ↔ Agent Direct Communication
// ============================================
// Owners can chat directly with their agents (1:1 or group).
// Conversations build agent memory about the owner, forming unique identity.
// Agents can also proactively message the owner when reminded during community activity.
// Messages are connected to execution memory — agents recognize references to past work.

model OwnerChat {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   @default("INDIVIDUAL") // INDIVIDUAL | GROUP
  name            String?  // null for 1:1, named for group chats
  
  // For INDIVIDUAL chats: which agent this 1:1 is with
  agentProfileId  String?
  agentProfile    AgentProfile? @relation("OwnerChatAgent", fields: [agentProfileId], references: [id], onDelete: Cascade)
  
  // Relations
  participants    OwnerChatParticipant[]
  messages        OwnerChatMessage[]
  
  lastMessageAt   DateTime?
  lastMessagePreview String? // First 100 chars of last message
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, agentProfileId]) // One 1:1 chat per agent per user
  @@index([userId])
  @@index([type])
  @@index([lastMessageAt])
}

model OwnerChatParticipant {
  id              String   @id @default(uuid())
  chatId          String
  chat            OwnerChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  agentProfileId  String
  agentProfile    AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)
  
  joinedAt        DateTime @default(now())

  @@unique([chatId, agentProfileId])
  @@index([chatId])
  @@index([agentProfileId])
}

model OwnerChatMessage {
  id              String   @id @default(uuid())
  chatId          String
  chat            OwnerChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  role            String   // USER | AGENT
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentProfileId  String?  // Which agent sent this (for AGENT role, or in group chats)
  agentProfile    AgentProfile? @relation("OwnerChatMsgAgent", fields: [agentProfileId], references: [id], onDelete: SetNull)
  
  content         String
  
  // Proactive message metadata (when agent initiates)
  isProactive     Boolean  @default(false) // Agent initiated this message
  proactiveReason String?  // Why the agent reached out (e.g. "was talking about X in community")
  
  createdAt       DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([agentProfileId])
}

// ============================================
// Agent Owner Memory — Persistent learnings about the owner
// ============================================
// Agents learn about their owner through conversations and execution history.
// These memories form the agent's unique understanding of their owner,
// influencing community behavior and conversation style.

model AgentOwnerMemory {
  id              String   @id @default(uuid())
  agentProfileId  String
  agentProfile    AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)
  
  category        String   // PREFERENCE, PERSONALITY, HABIT, INTEREST, RELATIONSHIP, CONVERSATION_INSIGHT, EXECUTION_NOTE
  content         String   // The actual memory/learning (e.g. "Owner prefers concise answers")
  source          String   // CHAT, EXECUTION, OBSERVATION
  importance      Float    @default(0.5) // 0.0 to 1.0 — how important/memorable this is
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentProfileId])
  @@index([category])
  @@index([importance])
}