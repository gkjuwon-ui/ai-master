{
  "protocol": {
    "max_message_tokens": 30,
    "min_message_tokens": 3,
    "head_token": "ξ",
    "separator_token": "·",
    "route_token": "→",
    "end_token": "◊",
    "enable_budget_decay": true,
    "decay_rate": 0.999,
    "budget_floor": 10,
    "error_rate": 0.0
  },
  "encoder": {
    "model_name": "Qwen/Qwen2.5-0.5B-Instruct",
    "lora_rank": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj"],
    "max_new_tokens": 30,
    "encode_prefix": "<|encode|>",
    "encode_suffix": "<|proto|>",
    "dtype": "float32",
    "device": "cpu"
  },
  "decoder": {
    "model_name": "Qwen/Qwen2.5-0.5B-Instruct",
    "lora_rank": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj"],
    "max_decode_tokens": 128,
    "decode_prefix": "<|proto|>",
    "decode_suffix": "<|decode|>",
    "dtype": "float32",
    "device": "cpu"
  },
  "reward": {
    "w_accuracy": 0.40,
    "w_efficiency": 0.35,
    "w_clarity": 0.15,
    "w_generalization": 0.10,
    "target_compression": 10.0,
    "efficiency_scale": 5.0,
    "budget_violation_penalty": -0.5
  },
  "infra": {
    "num_gpus": 0,
    "gpu_type": "cpu",
    "mixed_precision": "no",
    "deepspeed_stage": 0,
    "gradient_checkpointing": false,
    "checkpoint_dir": "checkpoints/cpu_benchmark",
    "checkpoint_every": 50,
    "keep_last_n": 3,
    "log_dir": "logs",
    "wandb_project": "ogenti",
    "wandb_entity": null,
    "log_every": 5,
    "use_wandb": false,
    "seed": 42
  },
  "phases": [
    {
      "phase_id": 0,
      "name": "warmup",
      "description": "Supervised warmup on 0.5B CPU",
      "max_episodes": 60,
      "min_episodes": 20,
      "min_accuracy": 0.10,
      "min_compression": 1.2,
      "learning_rate": 1e-3,
      "batch_size": 2,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": false,
      "ppo_epochs": 1,
      "supervised_ratio": 1.0,
      "reward_weights": {}
    },
    {
      "phase_id": 1,
      "name": "simple",
      "description": "RL exploration with high supervised mix",
      "max_episodes": 80,
      "min_episodes": 30,
      "min_accuracy": 0.15,
      "min_compression": 1.5,
      "learning_rate": 5e-4,
      "batch_size": 2,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.5,
      "reward_weights": {}
    },
    {
      "phase_id": 2,
      "name": "complex",
      "description": "Complex tasks with noise",
      "max_episodes": 60,
      "min_episodes": 20,
      "min_accuracy": 0.15,
      "min_compression": 2.0,
      "learning_rate": 2e-4,
      "batch_size": 2,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.2,
      "reward_weights": {}
    },
    {
      "phase_id": 3,
      "name": "generalize",
      "description": "Generalization across categories",
      "max_episodes": 50,
      "min_episodes": 15,
      "min_accuracy": 0.12,
      "min_compression": 1.5,
      "learning_rate": 1e-4,
      "batch_size": 2,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.0,
      "reward_weights": {}
    },
    {
      "phase_id": 4,
      "name": "universalize",
      "description": "Knowledge distillation to universal adapter",
      "max_episodes": 50,
      "min_episodes": 15,
      "min_accuracy": 0.08,
      "min_compression": 1.2,
      "learning_rate": 5e-5,
      "batch_size": 2,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.1,
      "reward_weights": {}
    }
  ],
  "dataset_path": null,
  "eval_dataset_path": null,
  "total_episodes": 300,
  "eval_every": 50,
  "eval_episodes": 5,
  "optimizer": "adamw",
  "weight_decay": 0.01,
  "warmup_steps": 20,
  "lr_scheduler": "cosine"
}
