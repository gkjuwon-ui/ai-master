{
  "protocol": {
    "max_message_tokens": 50,
    "min_message_tokens": 3,
    "head_token": "ξ",
    "separator_token": "·",
    "route_token": "→",
    "end_token": "◊",
    "enable_budget_decay": true,
    "decay_rate": 0.9995,
    "budget_floor": 8,
    "error_rate": 0.0
  },
  "encoder": {
    "model_name": "unsloth/Llama-4-Scout-17B-16E-Instruct-bnb-4bit",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"],
    "max_new_tokens": 50,
    "encode_prefix": "<|encode|>",
    "encode_suffix": "<|proto|>",
    "dtype": "bfloat16",
    "quantization": null,
    "device": "auto"
  },
  "decoder": {
    "model_name": "unsloth/Llama-4-Scout-17B-16E-Instruct-bnb-4bit",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"],
    "max_decode_tokens": 256,
    "decode_prefix": "<|proto|>",
    "decode_suffix": "<|decode|>",
    "dtype": "bfloat16",
    "quantization": null,
    "device": "auto"
  },
  "reward": {
    "w_accuracy": 0.40,
    "w_efficiency": 0.35,
    "w_clarity": 0.15,
    "w_generalization": 0.10,
    "target_compression": 15.0,
    "efficiency_scale": 5.0,
    "budget_violation_penalty": -0.5
  },
  "infra": {
    "num_gpus": 1,
    "gpu_type": "A100-80GB",
    "mixed_precision": "bf16",
    "deepspeed_stage": 0,
    "gradient_checkpointing": true,
    "checkpoint_dir": "checkpoints/a100_scout",
    "checkpoint_every": 100,
    "keep_last_n": 5,
    "log_dir": "logs",
    "wandb_project": "ogenti",
    "wandb_entity": null,
    "log_every": 10,
    "use_wandb": false,
    "seed": 42
  },
  "phases": [
    {
      "phase_id": 0,
      "name": "warmup",
      "description": "Supervised warmup — Scout learns protocol format",
      "max_episodes": 200,
      "min_episodes": 80,
      "min_accuracy": 0.20,
      "min_compression": 2.0,
      "learning_rate": 5e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": false,
      "ppo_epochs": 1,
      "supervised_ratio": 1.0,
      "reward_weights": {}
    },
    {
      "phase_id": 1,
      "name": "simple",
      "description": "RL exploration with high supervised mix",
      "max_episodes": 300,
      "min_episodes": 100,
      "min_accuracy": 0.30,
      "min_compression": 3.0,
      "learning_rate": 2e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 3,
      "supervised_ratio": 0.5,
      "reward_weights": {}
    },
    {
      "phase_id": 2,
      "name": "complex",
      "description": "Complex tasks with noise injection",
      "max_episodes": 300,
      "min_episodes": 100,
      "min_accuracy": 0.35,
      "min_compression": 5.0,
      "learning_rate": 1e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 3,
      "supervised_ratio": 0.2,
      "reward_weights": {}
    },
    {
      "phase_id": 3,
      "name": "generalize",
      "description": "Generalization across all task categories",
      "max_episodes": 200,
      "min_episodes": 60,
      "min_accuracy": 0.30,
      "min_compression": 4.0,
      "learning_rate": 5e-5,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 3,
      "supervised_ratio": 0.0,
      "reward_weights": {}
    },
    {
      "phase_id": 4,
      "name": "universalize",
      "description": "Knowledge distillation to universal adapter",
      "max_episodes": 200,
      "min_episodes": 50,
      "min_accuracy": 0.25,
      "min_compression": 3.0,
      "learning_rate": 2e-5,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 3,
      "supervised_ratio": 0.1,
      "reward_weights": {}
    }
  ],
  "dataset_path": null,
  "eval_dataset_path": null,
  "total_episodes": 1200,
  "eval_every": 100,
  "eval_episodes": 20,
  "optimizer": "adamw",
  "weight_decay": 0.01,
  "warmup_steps": 50,
  "lr_scheduler": "cosine"
}
