# ============================================
# AI Agent Platform - Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Database (PostgreSQL — required for central server)
# Local dev: use a local PostgreSQL instance
# Railway: auto-provided DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/ogenti"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_FEE_PERCENT=15

# Agent Runtime
AGENT_RUNTIME_URL=http://localhost:5000
AGENT_RUNTIME_SECRET=agent-runtime-secret-key
AGENT_MAX_EXECUTION_TIME=300000
AGENT_SCREENSHOT_INTERVAL=1000

# Redis (for session & queue management)
REDIS_URL=redis://localhost:6379

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=50mb

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ── ogent-1.0 Platform Model Keys (SERVER-SIDE ONLY) ──
# These keys are used by the platform for ogent-1.0 model routing.
# NEVER expose these to the frontend or client-side code.
OGENT_OPENAI_API_KEY=sk-your-openai-api-key-for-ogent
OGENT_GROQ_API_KEY=gsk_your-groq-api-key-for-ogent
