{
  "protocol": {
    "max_message_tokens": 30,
    "min_message_tokens": 3,
    "head_token": "ξ",
    "separator_token": "·",
    "route_token": "→",
    "end_token": "◊",
    "enable_budget_decay": false,
    "decay_rate": 0.999,
    "budget_floor": 15,
    "error_rate": 0.0
  },
  "encoder": {
    "model_name": "Qwen/Qwen2.5-3B-Instruct",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "max_new_tokens": 30,
    "encode_prefix": "<|encode|>",
    "encode_suffix": "<|proto|>"
  },
  "decoder": {
    "model_name": "Qwen/Qwen2.5-3B-Instruct",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "max_decode_tokens": 256,
    "decode_prefix": "<|proto|>",
    "decode_suffix": "<|decode|>"
  },
  "reward": {
    "w_accuracy": 0.40,
    "w_efficiency": 0.30,
    "w_clarity": 0.20,
    "w_generalization": 0.10,
    "target_compression": 15.0,
    "efficiency_scale": 5.0,
    "budget_violation_penalty": -1.0
  },
  "infra": {
    "num_gpus": 1,
    "gpu_type": "test",
    "mixed_precision": "no",
    "deepspeed_stage": 0,
    "gradient_checkpointing": false,
    "checkpoint_dir": "checkpoints",
    "checkpoint_every": 25,
    "keep_last_n": 2,
    "log_dir": "logs",
    "wandb_project": "ogenti",
    "wandb_entity": null,
    "log_every": 5,
    "use_wandb": false,
    "seed": 42
  },
  "phases": [
    {
      "phase_id": 0,
      "name": "warmup",
      "description": "Quick supervised warmup",
      "max_episodes": 30,
      "min_episodes": 10,
      "min_accuracy": 0.15,
      "min_compression": 1.5,
      "learning_rate": 5e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": false,
      "ppo_epochs": 2,
      "supervised_ratio": 1.0,
      "reward_weights": {}
    },
    {
      "phase_id": 1,
      "name": "simple",
      "description": "Quick RL exploration",
      "max_episodes": 30,
      "min_episodes": 10,
      "min_accuracy": 0.20,
      "min_compression": 2.0,
      "learning_rate": 2e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.3,
      "reward_weights": {}
    },
    {
      "phase_id": 2,
      "name": "complex",
      "description": "Quick complex test",
      "max_episodes": 20,
      "min_episodes": 10,
      "min_accuracy": 0.20,
      "min_compression": 2.0,
      "learning_rate": 1e-4,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.1,
      "reward_weights": {}
    },
    {
      "phase_id": 3,
      "name": "generalize",
      "description": "Quick generalize",
      "max_episodes": 10,
      "min_episodes": 5,
      "min_accuracy": 0.15,
      "min_compression": 1.5,
      "learning_rate": 5e-5,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.0,
      "reward_weights": {}
    },
    {
      "phase_id": 4,
      "name": "universalize",
      "description": "Quick distillation test",
      "max_episodes": 10,
      "min_episodes": 5,
      "min_accuracy": 0.10,
      "min_compression": 1.0,
      "learning_rate": 2e-5,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": true,
      "ppo_epochs": 2,
      "supervised_ratio": 0.1,
      "reward_weights": {}
    }
  ],
  "dataset_path": null,
  "eval_dataset_path": null,
  "total_episodes": 100,
  "eval_every": 25,
  "eval_episodes": 5,
  "optimizer": "adamw",
  "weight_decay": 0.01,
  "warmup_steps": 10,
  "lr_scheduler": "cosine"
}
