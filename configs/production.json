{
  "protocol": {
    "max_message_tokens": 30,
    "min_message_tokens": 3,
    "head_token": "ξ",
    "separator_token": "·",
    "route_token": "→",
    "end_token": "◊",
    "enable_budget_decay": true,
    "decay_rate": 0.999,
    "budget_floor": 5,
    "error_rate": 0.0
  },
  "encoder": {
    "model_name": "Qwen/Qwen2.5-3B-Instruct",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "max_new_tokens": 30,
    "encode_prefix": "<|encode|>",
    "encode_suffix": "<|proto|>"
  },
  "decoder": {
    "model_name": "Qwen/Qwen2.5-3B-Instruct",
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "max_decode_tokens": 256,
    "decode_prefix": "<|proto|>",
    "decode_suffix": "<|decode|>"
  },
  "reward": {
    "w_accuracy": 0.40,
    "w_efficiency": 0.30,
    "w_clarity": 0.20,
    "w_generalization": 0.10,
    "target_compression": 15.0,
    "efficiency_scale": 5.0,
    "budget_violation_penalty": -1.0
  },
  "infra": {
    "num_gpus": 1,
    "gpu_type": "A100-80GB",
    "mixed_precision": "bf16",
    "deepspeed_stage": 2,
    "gradient_checkpointing": true,
    "checkpoint_dir": "checkpoints",
    "checkpoint_every": 1000,
    "keep_last_n": 5,
    "log_dir": "logs",
    "wandb_project": "ogenti",
    "wandb_entity": null,
    "log_every": 50,
    "use_wandb": true,
    "seed": 42
  },
  "phases": [
    {
      "phase_id": 0,
      "name": "warmup",
      "description": "Supervised warmup — learn basic encode/decode",
      "max_episodes": 5000,
      "min_episodes": 2000,
      "min_accuracy": 0.30,
      "min_compression": 2.0,
      "learning_rate": 5e-4,
      "batch_size": 32,
      "num_agents": 2,
      "noise_prob": 0.0,
      "use_rl": false,
      "ppo_epochs": 4,
      "supervised_ratio": 1.0,
      "reward_weights": {
        "w_accuracy": 0.70,
        "w_efficiency": 0.10,
        "w_clarity": 0.15,
        "w_generalization": 0.05
      }
    },
    {
      "phase_id": 1,
      "name": "simple",
      "description": "RL exploration — simple single-hop tasks with light noise",
      "max_episodes": 15000,
      "min_episodes": 5000,
      "min_accuracy": 0.55,
      "min_compression": 5.0,
      "learning_rate": 2e-4,
      "batch_size": 16,
      "num_agents": 2,
      "noise_prob": 0.05,
      "use_rl": true,
      "ppo_epochs": 4,
      "supervised_ratio": 0.3,
      "reward_weights": {
        "w_accuracy": 0.50,
        "w_efficiency": 0.25,
        "w_clarity": 0.15,
        "w_generalization": 0.10
      }
    },
    {
      "phase_id": 2,
      "name": "complex",
      "description": "Multi-hop tasks, heavier noise, push compression harder",
      "max_episodes": 20000,
      "min_episodes": 8000,
      "min_accuracy": 0.65,
      "min_compression": 10.0,
      "learning_rate": 1e-4,
      "batch_size": 8,
      "num_agents": 3,
      "noise_prob": 0.10,
      "use_rl": true,
      "ppo_epochs": 4,
      "supervised_ratio": 0.1,
      "reward_weights": {
        "w_accuracy": 0.40,
        "w_efficiency": 0.35,
        "w_clarity": 0.15,
        "w_generalization": 0.10
      }
    },
    {
      "phase_id": 3,
      "name": "generalize",
      "description": "All task categories, high noise — force robust protocol",
      "max_episodes": 10000,
      "min_episodes": 4000,
      "min_accuracy": 0.70,
      "min_compression": 12.0,
      "learning_rate": 5e-5,
      "batch_size": 8,
      "num_agents": 2,
      "noise_prob": 0.15,
      "use_rl": true,
      "ppo_epochs": 4,
      "supervised_ratio": 0.0,
      "reward_weights": {
        "w_accuracy": 0.35,
        "w_efficiency": 0.30,
        "w_clarity": 0.15,
        "w_generalization": 0.20
      }
    },
    {
      "phase_id": 4,
      "name": "universalize",
      "description": "Knowledge distillation — Qwen teacher → Universal Adapter (PPH+PRH)",
      "max_episodes": 8000,
      "min_episodes": 3000,
      "min_accuracy": 0.75,
      "min_compression": 15.0,
      "learning_rate": 2e-5,
      "batch_size": 4,
      "num_agents": 2,
      "noise_prob": 0.20,
      "use_rl": true,
      "ppo_epochs": 4,
      "supervised_ratio": 0.1,
      "reward_weights": {
        "w_accuracy": 0.35,
        "w_efficiency": 0.30,
        "w_clarity": 0.10,
        "w_generalization": 0.25
      }
    }
  ],
  "dataset_path": "data/train.jsonl",
  "eval_dataset_path": "data/eval.jsonl",
  "total_episodes": 58000,
  "eval_every": 500,
  "eval_episodes": 100,
  "optimizer": "adamw",
  "weight_decay": 0.01,
  "warmup_steps": 200,
  "lr_scheduler": "cosine"
}
